func (h *{{.Snake}}Handler) List(c *gin.Context) {
	var req List{{.Pascal}}Request
	if err := c.ShouldBindQuery(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}
	result, err := h.service.List(c.Request.Context(), pagination.Query{
		Page:    req.Page,
		Size:    req.Size,
		Keyword: req.Keyword,
		Sort:    req.Sort,
	})
	if err != nil {
		h.logger.Error().Err(err).Msg("List {{.Component}} failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}
	list := make([]{{.Pascal}}Response, len(result.List))
	for i, m := range result.List {
		list[i] = to{{.Pascal}}Response(&m)
	}
	c.JSON(http.StatusOK, List{{.Pascal}}Response{
		Total: result.Total,
		List:  list,
	})
}

