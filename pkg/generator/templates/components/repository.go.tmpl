package repositories

import (
	"context"
	"fmt"
	"time"

	"models"
	"pkg/cache"

	"gorm.io/gorm"
)

type {{.Name}}Repository struct {
	db    *gorm.DB
	cache cache.Cache
}

func New{{.Name}}Repository(db *gorm.DB, cache cache.Cache) *{{.Name}}Repository {
	return &{{.Name}}Repository{db: db, cache: cache}
}

func (r *{{.Name}}Repository) Create(ctx context.Context, item *models.{{.Name}}) error {
	return r.db.WithContext(ctx).Create(item).Error
}

func (r *{{.Name}}Repository) GetByID(ctx context.Context, id int) (*models.{{.Name}}, error) {
	cacheKey := fmt.Sprintf("{{.SnakeName}}:%d", id)

	// 1. 查缓存
	var item models.{{.Name}}
	if err := r.cache.GetJSON(ctx, cacheKey, &item); err == nil {
		return &item, nil
	}

	// 2. 查数据库
	if err := r.db.WithContext(ctx).First(&item, id).Error; err != nil {
		return nil, err
	}

	// 3. 写缓存，5 分钟过期
	_ = r.cache.SetJSON(ctx, cacheKey, item, 5*time.Minute)

	return &item, nil
}

func (r *{{.Name}}Repository) Update(ctx context.Context, item *models.{{.Name}}) error {
	if err := r.db.WithContext(ctx).Save(item).Error; err != nil {
		return err
	}
	// 删除缓存
	_ = r.cache.Delete(ctx, fmt.Sprintf("{{.SnakeName}}:%d", item.ID))
	return nil
}

func (r *{{.Name}}Repository) Delete(ctx context.Context, id int) error {
	if err := r.db.WithContext(ctx).Delete(&models.{{.Name}}{}, id).Error; err != nil {
		return err
	}
	// 删除缓存
	_ = r.cache.Delete(ctx, fmt.Sprintf("{{.SnakeName}}:%d", id))
	return nil
}
