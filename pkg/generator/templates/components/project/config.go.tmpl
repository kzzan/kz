package config

import (
	"github.com/spf13/viper"
)

type Config struct {
	Database string
	Port     string
}

func Init() *Config {
	viper.SetDefault("database", "{{.Database}}")
	viper.SetDefault("port", "8080")

	return &Config{
		Database: viper.GetString("database"),
		Port:     viper.GetString("port"),
	}
}
